✅ Step 3: Only scroll when errors EXIST

Refactor effect:

useEffect(() => {
  if (scrollTimeoutRef.current) {
    clearTimeout(scrollTimeoutRef.current);
    scrollTimeoutRef.current = null;
  }
  const hasErrors = Object.values(errors).some(Boolean);
  if (!hasErrors) {
    lastErrorStateRef.current = '';
    resetErrorFocus();
    return;
  }
  const errorStateKey = `${errors.accuratelyReflects}-${errors.alternativeClassification}-${errors.taxDeclaration}`;
  if (lastErrorStateRef.current === errorStateKey) return;
  lastErrorStateRef.current = errorStateKey;
  const currentErrorFields = {
    [ERROR_FIELDS.ACCURATELY_REFLECTS]: errors.accuratelyReflects
      ? { ref: accuratelyReflectsRef, message: errors.accuratelyReflects }
      : undefined,
    [ERROR_FIELDS.ALTERNATIVE_CLASSIFICATION]: errors.alternativeClassification
      ? { ref: alternativeClassificationRef, message: errors.alternativeClassification }
      : undefined,
    [ERROR_FIELDS.TAX_DECLARATION]: errors.taxDeclaration
      ? { ref: taxDeclarationRef, message: errors.taxDeclaration }
      : undefined,
  };
  scrollTimeoutRef.current = setTimeout(() => {
    focusFirstError(currentErrorFields, ERROR_ORDER);
  }, 300);
}, [errors]);

⸻

